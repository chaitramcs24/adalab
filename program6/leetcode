#include <limits.h>

int minSwap(int* nums1, int nums1Size, int* nums2, int nums2Size) {
    int keep = 0;  
    int swap = 1;  

    for (int i = 1; i < nums1Size; i++) {
        int newKeep = INT_MAX;
        int newSwap = INT_MAX;

        
        if (nums1[i] > nums1[i-1] && nums2[i] > nums2[i-1]) {
            newKeep = keep;
            newSwap = swap + 1;
        }

       
        if (nums1[i] > nums2[i-1] && nums2[i] > nums1[i-1]) {
            if (swap < newKeep)
                newKeep = swap;
            if (keep + 1 < newSwap)
                newSwap = keep + 1;
        }

        keep = newKeep;
        swap = newSwap;
    }

    return (keep < swap) ? keep : swap;
}
