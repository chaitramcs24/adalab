#include <stdio.h>
#define MAX 20
#define INF 9999
int parent[MAX];
int find(int i) {
    while (parent[i] != i)
        i = parent[i];
    return i;
}
void unionSet(int i, int j) {
    parent[i] = j;
}
int main() {
    int n, cost[MAX][MAX];
    int i, j, u, v, min, mincost = 0;
    int edges = 0;
    printf("Enter number of vertices: ");
    scanf("%d", &n);
    printf("Enter cost adjacency matrix:\n");
    for (i = 0; i < n; i++) {
        for (j = 0; j < n; j++) {
            scanf("%d", &cost[i][j]);
            if (cost[i][j] == 0)
                cost[i][j] = INF;
        }
    }
    for (i = 0; i < n; i++)
        parent[i] = i;
    printf("\nEdges in MST:\n");
    while (edges < n - 1) {
        min = INF;
        for (i = 0; i < n; i++) {
            for (j = 0; j < n; j++) {
                if (cost[i][j] < min) {
                    min = cost[i][j];
                    u = i;
                    v = j;
                }
            }
        }
        int set_u = find(u);
        int set_v = find(v)
        if (set_u != set_v) {
            printf("%d - %d : %d\n", u, v, min);
            mincost += min;
            unionSet(set_u, set_v);
            edges++;
        }
        cost[u][v] = cost[v][u] = INF;
    }
    printf("Minimum Cost = %d\n", mincost);
    return 0;
}
